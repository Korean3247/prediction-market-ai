# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional
NEWS_API_KEY=your_news_api_key_here

# Database
DATABASE_URL=sqlite:///./prediction_market.db

# Market Filters
MIN_LIQUIDITY=1000.0
MIN_VOLUME_24H=100.0
MIN_HOURS_TO_RESOLVE=24.0
MAX_SPREAD=0.15

# Decision Thresholds
MIN_CONFIDENCE_SCORE=0.6
MIN_EDGE=0.05
MIN_EV=0.02

# Position Sizing
MAX_POSITION_SIZE=0.05
BANKROLL=1000.0
KELLY_FRACTION=0.25

# Scheduler
SCAN_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO

# Telegram Alerts (optional)
TELEGRAM_BOT_TOKEN=  # Optional: get from @BotFather on Telegram
TELEGRAM_CHAT_ID=    # Optional: your Telegram chat/channel ID

# Market scanning
MAX_MARKETS_TO_SCAN=500
